# Spring Boot / Supabase environment variables
# Copy to .env and fill in your Supabase credentials

PORT=8080

# Supabase PostgreSQL connection
# Format: jdbc:postgresql://<host>:<port>/<dbname>
SUPABASE_DB_URL=jdbc:postgresql://db.xxxxxxxxxxxx.supabase.co:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-supabase-db-password

# CORS: comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:4200,https://your-portfolio.vercel.app
